# Remote deployment candidate example.
# Phase 2E target: PlayMCP in KC Git source build readiness.
# Fill real secret values at deploy time. Do not commit runtime secrets.
# Do not record PAT, endpoint URL, or bearer token in docs/logs/history.
# CHECKTIME_ALLOWED_ORIGINS may stay blank until the actual PlayMCP origin is confirmed.

CHECKTIME_AUTH_MODE=bearer
CHECKTIME_BEARER_TOKEN=<set-at-runtime>
CHECKTIME_ALLOWED_ORIGINS=<confirm-playmcp-origin-before-use-or-leave-blank>
CHECKTIME_REQUEST_TIMEOUT_SECONDS=10
CHECKTIME_MAX_BODY_BYTES=1048576
PORT=8080
CHECKTIME_MCP_DATA_DIR=/app/data
